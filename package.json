{
  "name": "diy-guide-embedder",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A simple JS library to embed .mdx DIY guides into existing HTML websites.",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@openpawlabs/diy-guides-ui": "^1.5.0",
    "online-3d-viewer": "^0.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "@openpawlabs/diy-guides-ui": "link:../diy-guides-ui-react"
    }
  }
}
